+void riscv_cpu_set_local_irq(CPURISCVState *env, int irq, int level)
+{
+    uint64_t bit;
+    int w;
+
+    if (irq < 32 || irq >= 128) {
+        return;
+    }
+    bit = 1ULL << (irq & 63);
+    w = irq >> 6;
+
+    BQL_LOCK_GUARD();
+    if (level) {
+        env->ws63_locipd[w] |= bit;
+    } else {
+        env->ws63_locipd[w] &= ~bit;
+    }
+    riscv_cpu_interrupt(env);
+}
