+/*
+ * HiSilicon WS63 custom local interrupts (IRQ 32-95). Returns the lowest
+ * enabled+pending IRQ number (>= 32), or RISCV_EXCP_NONE. Delivered with
+ * mcause = irq via the standard vectored-mtvec path in riscv_cpu_do_interrupt.
+ * (Priority/PRITHD is not yet modeled — lowest-number-first; refine later.)
+ */
+static int ws63_local_irq_pending(CPURISCVState *env)
+{
+    int w;
+    for (w = 0; w < 2; w++) {
+        uint64_t active = env->ws63_locipd[w] & env->ws63_locien[w];
+        if (active) {
+            return w * 64 + ctz64(active);
+        }
+    }
+    return RISCV_EXCP_NONE;
+}
