+/*
+ * HiSilicon WS63 "riscv31" application core: RV32IMFC_Zicsr, hard-float ilp32f,
+ * no A (atomics), no MMU. Presets the exact ISA the hw/riscv/ws63 machine needs
+ * so `-cpu ws63` works, and so machine init need not poke the configurable
+ * CPU's per-letter properties (those are unavailable under -accel qtest).
+ *
+ * Zcf (compressed float load/store) is enabled; Zca/Zcb/Zcmp/Zcmt are NOT — the
+ * HiSilicon "xlinx" custom code-size instructions (push/pop/popret, uxtb/uxth)
+ * occupy that compressed (funct3=100) encoding space and are decoded in
+ * target/riscv/insn_trans/trans_xlinx.c.inc; enabling Zcb/Zcmp would mis-decode
+ * them. Zicntr is kept for rdcycle/rdtime used by firmware timing loops.
+ */
+static void rv32_ws63_cpu_init(Object *obj)
+{
+    CPURISCVState *env = &RISCV_CPU(obj)->env;
+    RISCVCPU *cpu = RISCV_CPU(obj);
+
+    riscv_cpu_set_misa_ext(env, RVI | RVM | RVF | RVC);
+    env->priv_ver = PRIV_VERSION_LATEST;
+#ifndef CONFIG_USER_ONLY
+    set_satp_mode_max_supported(cpu, VM_1_10_MBARE);
+#endif
+
+    cpu->cfg.ext_zicsr = true;
+    cpu->cfg.ext_zifencei = true;
+    cpu->cfg.ext_zicntr = true;
+    cpu->cfg.ext_zcf = true;
+    cpu->cfg.pmp = true;
+}
