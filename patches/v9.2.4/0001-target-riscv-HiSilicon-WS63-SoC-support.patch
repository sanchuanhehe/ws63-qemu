+/*
+ * HiSilicon WS63 custom local interrupts (IRQ 32-95). Returns the lowest
+ * enabled+pending IRQ number (>= 32), or RISCV_EXCP_NONE. Delivered with
+ * mcause = irq via the standard vectored-mtvec path in riscv_cpu_do_interrupt.
+ * (Priority/PRITHD is not yet modeled — lowest-number-first; refine later.)
+ */
+static int ws63_local_irq_pending(CPURISCVState *env)
+{
+    /*
+     * WS63 priority/threshold: each IRQ has a 4-bit priority in LOCIPRI (8/reg,
+     * priority irq = ws63_locipri[irq/8] bits[(irq%8)*4 +: 4]); higher value =
+     * more urgent. An IRQ is eligible only when its priority > PRITHD (strict).
+     * Among eligible pending+enabled IRQs, deliver the highest priority; ties go
+     * to the lowest IRQ number. (Default priority 1, PRITHD 0 -> deliver by
+     * number, preserving the pre-priority behaviour.)
+     */
+    int best_irq = RISCV_EXCP_NONE;
+    int best_pri = -1;
+    int w;
+    for (w = 0; w < 2; w++) {
+        uint64_t active = env->ws63_locipd[w] & env->ws63_locien[w];
+        while (active) {
+            int b = ctz64(active);
+            int irq = w * 64 + b;
+            int pri = (env->ws63_locipri[(irq >> 3) & 15] >> ((irq & 7) * 4)) & 0xF;
+            active &= active - 1; /* clear lowest set bit */
+            if (pri > (int)env->ws63_prithd && pri > best_pri) {
+                best_pri = pri;
+                best_irq = irq; /* iterate ascending -> ties keep lowest IRQ */
+            }
+        }
+    }
+    return best_irq;
+}
+
 static int riscv_cpu_local_irq_pending(CPURISCVState *env)
 {
     uint64_t irqs, pending, mie, hsie, vsie, irqs_f, irqs_f_vs;
@@ -530,6 +566,14 @@ static int riscv_cpu_local_irq_pending(CPURISCVState *env)
                                         irqs, env->miprio);
     }
 
+    /* WS63 custom local interrupts (IRQ >= 32), gated by M-mode enable. */
+    if (mie && !env->virt_enabled) {
+        int ws63_irq = ws63_local_irq_pending(env);
+        if (ws63_irq != RISCV_EXCP_NONE) {
+            return ws63_irq;
+        }
+    }
+
     /* Check for virtual S-mode interrupts. */
     irqs_f = env->mvip & (env->mvien & ~env->mideleg) & env->sie;
 
@@ -728,7 +772,9 @@ void riscv_cpu_interrupt(CPURISCVState *env)
 
     vstip = env->vstime_irq ? MIP_VSTIP : 0;
 
-    if (env->mip | vsgein | vstip | irqf) {
+    if (env->mip | vsgein | vstip | irqf |
+        (env->ws63_locipd[0] & env->ws63_locien[0]) |
+        (env->ws63_locipd[1] & env->ws63_locien[1])) {
         cpu_interrupt(cs, CPU_INTERRUPT_HARD);
     } else {
         cpu_reset_interrupt(cs, CPU_INTERRUPT_HARD);
@@ -751,6 +797,26 @@ uint64_t riscv_cpu_update_mip(CPURISCVState *env, uint64_t mask, uint64_t value)
     return old;
 }
 
+void riscv_cpu_set_local_irq(CPURISCVState *env, int irq, int level)
+{
+    uint64_t bit;
+    int w;
+
+    if (irq < 32 || irq >= 128) {
+        return;
+    }
+    bit = 1ULL << (irq & 63);
+    w = irq >> 6;
+
+    BQL_LOCK_GUARD();
+    if (level) {
+        env->ws63_locipd[w] |= bit;
+    } else {
+        env->ws63_locipd[w] &= ~bit;
+    }
+    riscv_cpu_interrupt(env);
+}
